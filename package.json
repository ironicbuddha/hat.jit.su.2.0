{
  "name": "hat-jitsu-2",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "pnpm lint:md && pnpm lint:ts && pnpm lint:css",
    "lint:md": "markdownlint-cli2 \"README.md\" \"AGENTS.md\" \"WORKING_MEMORY.md\" \"CONTEXT.md\" \"constitution.md\"",
    "lint:ts": "eslint .",
    "lint:css": "stylelint \"**/*.{css,pcss,scss}\" --allow-empty-input",
    "format": "prettier --write \"**/*.md\" \"**/*.{ts,tsx,js,jsx,json,mjs}\" \"**/*.{css,pcss,scss}\"",
    "format:check": "prettier --check \"**/*.md\" \"**/*.{ts,tsx,js,jsx,json,mjs}\" \"**/*.{css,pcss,scss}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@upstash/redis": "^1.35.6",
    "@t3-oss/env-nextjs": "^0.13.8",
    "ably": "^2.12.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.55.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.39",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.4.0",
    "jsdom": "^27.0.1",
    "markdownlint-cli2": "^0.18.1",
    "prettier": "^3.6.2",
    "stylelint": "^16.25.0",
    "stylelint-config-standard": "^39.0.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  }
}
